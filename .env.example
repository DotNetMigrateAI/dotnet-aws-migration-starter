# =============================================
# .NET AWS Migration Starter — Environment Config
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!
# =============================================

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# App Config
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Database (replace with your RDS endpoint post-migration)
DB_CONNECTION_STRING=Server=localhost;Database=SampleDb;User Id=sa;Password=YourPassword;

# Secrets Manager (ARN of your secret)
AWS_SECRET_ARN=arn:aws:secretsmanager:ap-south-1:123456789012:secret:my-app-secret

# ECR Repository
ECR_REPOSITORY_URI=123456789012.dkr.ecr.ap-south-1.amazonaws.com/sample-app

# ECS
ECS_CLUSTER_NAME=migration-cluster
ECS_SERVICE_NAME=sample-app-service
